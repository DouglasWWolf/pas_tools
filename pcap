#==============================================================================
# Play back (i.e., transmit) packets from a PCAP file
#==============================================================================
playback()
{
    # Find out if the user wants to replay and previously played file
    replay=0
    if [ "$1" == "-replay" ]; then
        shift
        replay=1
        channel=$1
        ipg=$2
    else
        replay=0;
        channel=$1
        filename=$2
        ipg=$3
    fi

    # Make sure channel number is valid
    if [ "$channel" != "0" ] && [ "$channel" != "1" ]; then
        echo "Invalid channel number"
        return
    fi

    # Makes sure the user gave us a valid filename
    if [ $replay -eq 0 ]; then
        if [ -z $filename ]; then
            echo "Missing filename"
            return
        fi

        if [ ! -f $filename ]; then
            echo "File $filename doesn't exist"
            return 
        fi
    fi

    # If no inter-packet gap was specified, use zero
    test -z $ipg && ipg=0

    # Fetch the register definitions for this channel
    if [ $channel -eq 0 ]; then
              REG_PB_IPG=$CH0_PB_IPG
            REG_PB_START=$CH0_PB_START
        REG_PB_HOST_ADDR=$CH0_PB_HOST_ADDR
        REG_PB_PKTS_SENT=$CH0_PB_PKTS_SENT
    else
              REG_PB_IPG=$CH1_PB_IPG
            REG_PB_START=$CH1_PB_START
        REG_PB_HOST_ADDR=$CH1_PB_HOST_ADDR
        REG_PB_PKTS_SENT=$CH1_PB_PKTS_SENT
    fi


    # Find out where the contiguous buffer is and how big it is
    get_contig
    if [ -z $CONTIG_SIZE ]; then
        echo "NO CONTIGUOUS SPACE DECLARED!"
        return
    fi

    # Make sure the contiguous buffer is large enough for an 8GB
    # space to store captured packets, followed by two 4GB spaces
    # to unpack pcap files into
    if [ $CONTIG_SIZE -lt $((0x400000000)) ]; then
        echo "Contiguous buffer must be at least 16GB"
        return
    fi

    # Each channel gets its own 4GB buffer, and those buffers are
    # allocated after the 8GB packet-capture buffer
    if [ $channel -eq 0 ]; then
        addr=$((CONTIG_ADDR + 0x200000000))
    else
        addr=$((CONTIG_ADDR + 0x300000000))      
    fi  

    # Make sure there's not a playback already in process!
    if [ $(pcireg -dec $REG_PB_START) -ne 0 ]; then
        echo "Playback is already active!"
        return
    fi
   
    # Unpack the PCAP file into RAM
    if [ $replay -eq 0 ]; then
        physram $addr -clear
        unpack_pcap -addr $addr -size 0x100000000 $filename
        test $? -ne 0 && return
    fi

    # Connect the playback logic the CMAC
    set_tx_mux $channel 1

    # Fetch the link status bits
    local link_bits=$(pcireg -dec $REG_LINK_STATUS)

    # Fetch the link status for this channel
    if [ $channel -eq 0 ]; then
        link_status=$((link_bits & 1))
    else
        link_status=$((link_bits & 2))
    fi
    
    # Don't try to send packets if there's no Ethernet link
    if [ $link_status -eq 0 ]; then
        echo "No Ethernet Link!"
        return
    fi

    # Tell the FPGA where to read data from in host RAM
    pcireg $REG_PB_HOST_ADDR $addr

    # Tell the FPGA what value to use for an inter-packet gap
    pcireg $REG_PB_IPG $ipg

    # Start sending packet from the PCAP file we loaded
    pcireg $REG_PB_START 1

    # Wait for the FPGA to finish sending packets
    while [ $(pcireg -dec $REG_PB_START) -ne 0 ]; do
        sleep .1
    done

    # Tell the caller how many packets were sent
    printf "%8u packets sent on QSFP_%u\n" $(pcireg -dec $REG_PB_PKTS_SENT) $channel

}
