#==============================================================================
# This causes generated packets to be transmitted.  This is useful for 
# testing the RTL when there are loopback connectors plugged in
#==============================================================================
generate_packets()
{
    local channel=$1
    local size=$2
    local count=$3
    local REG_SEND_COUNT=0
    local REG_SEND_SIZE=0
    local REG_SEND=0

    if [ -z $channel ] || [ $channel -lt 0 ] || [ $channel -gt 1 ]; then
        echo "Invalid channel number"
        return
    fi

    # Set some reasonable defaults for missing parameters
    test -z $size  && size=4096
    test -z $count && count=10

    # Determine which registers we need to access
    if [ $channel -eq 0 ]; then
              REG_SEND=$CH0_SEND
         REG_SEND_SIZE=$CH0_SEND_SIZE
        REG_SEND_COUNT=$CH0_SEND_COUNT
    else
              REG_SEND=$CH1_SEND
         REG_SEND_SIZE=$CH1_SEND_SIZE
        REG_SEND_COUNT=$CH1_SEND_COUNT
    fi

    # Connect the packet generator to the CMAC
    set_tx_mux $channel 0

    # Start generating packets
    pcireg $REG_SEND_COUNT $count
    pcireg $REG_SEND_SIZE  $size
    pcireg $REG_SEND       1

    # Wait for packet generation to be complete
    while [ $(pcireg -dec $REG_SEND) -ne 0 ]; do
        sleep .1
    done
}
#==============================================================================

#==============================================================================
# Selects an input for a TX mux.
#   Input port 0 = Packet Gen/Xmit mechanism is connected to CMAC
#   Input port 1 = Playback mechanism is connected to CMAC
#==============================================================================
set_tx_mux()
{
    channel=$1
    value=$2
    if [ "$channel" == "0" ]; then
        pcireg $CH0_PB_MUX_SEL $value
    elif [ "$channel" == "1" ]; then
        pcireg $CH1_PB_MUX_SEL $value
    fi
}
