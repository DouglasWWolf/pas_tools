#==============================================================================
# Display the Ethernet link status
#==============================================================================
display_link_status()
{
    local link_ok=link_ok
    local no_link=no_link
    local bits=$(pcireg -dec $REG_LINK_STATUS)

    if [ $bits -eq 3 ]; then
        echo $link_ok
        exit 0
    else
        echo -n "QSFP_0 "
        test $(( bits & 1)) -ne 0 && echo $link_ok || echo $no_link
        echo -n "QSFP_1 "
        test $(( bits & 2)) -ne 0 && echo $link_ok || echo $no_link
        exit 1
    fi
}
