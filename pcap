#==============================================================================
# This dumps captured packets to a file
#==============================================================================
dump_packets()
{
    local channel=$1
    local max_packets=$2
    local max_blocks=0
    local blocks=0
    local packets=0
    local REG_HOST_ADDR=0
    local REG_BLOCK_COUNT=0
    local REG_PACKET_COUNT=0
    local REG_COPY_TO_HOST=0
    local REG_TS_FREQUENCY=0

    # Determine which registers we need to access
    if [ $channel -eq 0 ]; then
           REG_HOST_ADDR=$CH0_HOST_ADDR
         REG_BLOCK_COUNT=$CH0_BLOCK_COUNT
        REG_PACKET_COUNT=$CH0_PACKET_COUNT
        REG_COPY_TO_HOST=$CH0_COPY_TO_HOST
        REG_TS_FREQUENCY=$CH0_TS_FREQUENCY
    else
           REG_HOST_ADDR=$CH1_HOST_ADDR
         REG_BLOCK_COUNT=$CH1_BLOCK_COUNT
        REG_PACKET_COUNT=$CH1_PACKET_COUNT
        REG_COPY_TO_HOST=$CH1_COPY_TO_HOST
        REG_TS_FREQUENCY=$CH1_TS_FREQUENCY
    fi

    # How many packets were captured and how many blocks did it take?
     blocks=$(pcireg -dec $REG_BLOCK_COUNT)
    packets=$(pcireg -dec $REG_PACKET_COUNT)

    # If the user didn't tell us how many packets to fetch, then we will
    # fetch every packet of every block.
    # If the user DID tell us how many packets to fetch, try to optimize
    # the number of blocks that we map
    if [ -z $max_packets ]; then
        max_packets=$packets
         max_blocks=$blocks
    else
         max_blocks=$((3 * max_packets))
         test $max_blocks -gt $blocks && max_blocks=$blocks
    fi

    # Find out the frequency of the timestamp clock
    tsfreq=$(pcireg -dec $REG_TS_FREQUENCY)


    # Find out where the contiguous buffer is and how big it is
    get_contig
    if [ -z $CONTIG_SIZE ]; then
        echo "NO CONTIGUOUS SPACE DECLARED!"
        return
    fi

    # Find out how much RAM it will take to accomodate the number
    # of blocks that were captured
    bytes_required=$((blocks * 4096))

    # Will the number of blocks fit into our contiguous buffer?
    if [ $bytes_required -gt $CONTIG_SIZE ]; then
        echo "Captured packets won't fit in contiguous RAM!"
        return 
    fi

    # Tell the FPGA where our contiguous buffer is
    pcireg $REG_HOST_ADDR $CONTIG_ADDR

    # For safety, clear the beginning of the contiguous buffer
    physram $CONTIG_ADDR -clear

    # Tell the FPGA to copy the packets to host RAM, and wait 
    # for it to finish
    pcireg $REG_COPY_TO_HOST 1
    while [ $(pcireg -dec $REG_COPY_TO_HOST) -ne 0 ]; do
        sleep .1
    done

    # Dump the packets to a file
    local filename=$(printf "ch%i_packets.pcap" $channel)
    dump_fast_pcap -packets $max_packets \
                   -blocks  $max_blocks  \
                   -addr    $CONTIG_ADDR \
                   -tsfreq  $tsfreq      \
                    $filename

}
