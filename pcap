    # Make sure channel number is valid
    if [ $channel != "0" ] && [ $channel != "1" ]; then
        echo "Invalid channel number"
        return
    fi

    # Determine the base address of the CMAC AXI4-Lite interface
    test $channel -eq 0 && cmac_base=0x10000 || cmac_base=0x20000

    # Fetch the statistics by writing a 1 to TICK_REG
    pcireg $((cmac_base + 0x2B0)) 1
    
    # Fetch the RX status reg
    value=$(pcireg -dec $((cmac_base + 0x204)))
    printf "%32s:\n" "STAT_RX_STATUS_REG"
