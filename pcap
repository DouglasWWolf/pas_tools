#==============================================================================
# Uses the registers defined in "fast_pcap_reg.h" to define a new set of
# environment variables, replacing "REG_xxx" with "CH0_xxx" and "CH1_xxx"
#==============================================================================
rename_registers()
{
    while IFS='=' read -r name addr; do
        test -z $addr && continue
        local addr0=$((addr))
        local addr1=$((addr + 0x1000))
        local new_name0=$(echo $name | sed 's/^REG_/CH0_/g')
        local new_name1=$(echo $name | sed 's/^REG_/CH1_/g')
        local cmd0=$(printf "%s=0x%X" $new_name0 $addr0)
        local cmd1=$(printf "%s=0x%X" $new_name1 $addr1)
        eval $cmd0
        eval $cmd1
    done <<< $(set | grep "^REG_")
}
