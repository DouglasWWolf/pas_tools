#==============================================================================
# This captures packets and writes them to a file
#==============================================================================
capture()
{
    # Determine how many packets we're going to dump to a file
    local max_packets=$1

    # Start the capture on both channels
    pcireg $CH0_ENABLE 1
    pcireg $CH1_ENABLE 1

    # Wait for the user to press ENTER before dumping packets
    echo "Send packets, and press ENTER to dump them to files"
    read

    # Halt the capture
    pcireg $CH0_ENABLE 0
    pcireg $CH1_ENABLE 0

    # Wait for the capture to complete on both channels
    while [ $(pcireg -dec $CH0_CAP_COMPLETE) -eq 0 ]; do
        sleep .1
    done
    while [ $(pcireg -dec $CH1_CAP_COMPLETE) -eq 0 ]; do
        sleep .1
    done

    # Find out how many packets we captured on each QSFP port
    local packets0=$(pcireg -dec $CH0_PACKET_COUNT)
    local packets1=$(pcireg -dec $CH1_PACKET_COUNT)
    printf "%8u packets captured on QSFP_0\n" $packets0
    printf "%8u packets captured on QSFP_1\n" $packets1

    test $packets0 -gt 0 && dump_packets 0 $max_packets
    test $packets1 -gt 0 && dump_packets 1 $max_packets

    # If packet files were created, tell the user where they are
    if [ $packets0 -gt 0 ] ||  [ $packets1 -gt 0 ]; then
        echo "Packet files are in $folder"
    fi

    return
}
