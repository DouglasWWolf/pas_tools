# Make sure the correct RTL is loaded
if [ $(pcireg -dec 20) -ne 71026 ]; then
    echo "The fast_pcap bitstream is not loaded into the FPGA!"
    exit
fi

# Fetch the register definitions for this RTL design
source bash_registers $(dirname $0)/fast_pcap_reg.h
rename_registers

# We don't have a base address for CMAC AXI queries yet
cmac_base=0

if [ "$1" == "capture" ]; then
    shift
    folder=~/packets
    mkdir -p $folder
    cd $folder
    capture $1
    exit
fi

if [ "$1" == "play" ]; then
    shift
    playback $1 $2 $3 $4 $5
    exit
fi

if [ "$1" == "replay" ]; then
    shift
    playback -replay $1 $2 $3 $4 $5
    exit
fi

if [ "$1" == "xmit" ]; then
    shift
    generate_packets $1 $2 $3
    exit
fi

if [ "$1" == "loopback" ]; then
    shift
    loopback $1
    exit
fi

if [ "$1" == "rsfec" ]; then
    shift
    rsfec $1
    exit
fi

if [ "$1" == "reset_gt" ]; then
    shift
    reset_gt
    exit
fi


if [ "$1" == "link" ]; then
    shift
    display_link_status
    exit
fi

if [ "$1" == "stats" ]; then
    shift
    display_statistics $1
    exit
fi

echo "pcap link"
echo "pcap capture [max_packets]"
echo "pcap play <0|1> <filename> [ipg]"
echo "pcap replay <0|1> [ipg]"
echo "pcap loopback [on | off]"
