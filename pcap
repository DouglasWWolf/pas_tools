#==============================================================================
# Display the contents of a CMAC register
#==============================================================================
showreg()
{
    name=$1
    offset=$2
    
    # Compute the address we want to read
    addr=$((cmac_base + offset))

    printf "%32s = " $name
    pcireg $addr
}
