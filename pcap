#==============================================================================
# This turns Ethernet loopback mode on or off
#==============================================================================
loopback()
{
    local state0=""
    local state1=""
    local reg0=0x1_0090
    local reg1=0x2_0090

    if [ -z $1 ]; then
        test $(pcireg -dec $reg0) -eq 0 && state0="off" || state0="on"
        test $(pcireg -dec $reg1) -eq 0 && state1="off" || state1="on"
        echo "QSFP_0 loopback is" $state0
        echo "QSFP_1 loopback is" $state1
        return
    fi

    if [ $1 == "off" ]; then
        pcireg $reg0 0
        pcireg $reg1 0
    else
        pcireg $reg0 1
        pcireg $reg1 1
    fi
}
#==============================================================================


#==============================================================================
# This resets all transceivers of the CMACs
#==============================================================================
reset_gt()
{
    local reg0=0x1_0000
    local reg1=0x2_0000

    pcireg $reg0 1
    pcireg $reg1 1
    sleep .1
    pcireg $reg0 0
    pcireg $reg1 0
}
#==============================================================================


#==============================================================================
# This turns Ethernet RS-FEC mode on or off
#==============================================================================
rsfec()
{
    local state0=""
    local state1=""
    local reg0=0x1_107C
    local reg1=0x2_107C

    if [ -z $1 ]; then
        local current0=$(pcireg -dec $reg0)
        local current1=$(pcireg -dec $reg1)
        test $((current0 & 3)) -eq 3 && state0="on" || state0="off"
        test $((current1 & 3)) -eq 3 && state1="on" || state1="off"
        echo "QSFP_0 RS-FEC is" $state0
        echo "QSFP_1 RS-FEC is" $state1
        return
    fi

    if [ $1 == "off" ]; then
        pcireg $reg0 0
        pcireg $reg1 0
    else
        pcireg $reg0 3
        pcireg $reg1 3
    fi
}
